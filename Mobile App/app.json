{
  "expo": {
    "name": "Sapien Score",
    "slug": "sapien_score",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sapianlogo.png",
    "scheme": "sapienscore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/sapianlogo.png",
      "color": "#FF0000",
      "androidMode": "default",
      "androidCollapsedTitle": "Sapien Score"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sapien",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sapianlogo.png",
        "backgroundColor": "#ffffff"
      },
      "usesCleartextTraffic": true,
      "softWareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "NOTIFICATIONS",
        "INTERNET"
      ],
      "package": "com.sapienscore.sapien_score",
      "icon": "./assets/images/sapianlogo.png"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sapianlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/sapianlogo.png",
          "color": "#ffffff",
          "iosDisplayInForeground": true,
          "androidDisplayInForeground": true
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2bb5ccd-5256-4a16-bd26-59e126fbcff6"
      }
    }
  }
}
