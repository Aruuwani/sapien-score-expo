# ===========================================
# Sapien Score Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

PORT=5000
NODE_ENV=development

# MongoDB (use authenticated URI in production!)
# Format: mongodb://username:password@host:port/database?authSource=database
MONGO_URI=mongodb://localhost:27017/sapienDB

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# JWT
JWT_SECRET=your_jwt_secret_here

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-east-1
AWS_BUCKET=your_bucket_name
AWS_PUBLICURL=https://your_bucket.s3.amazonaws.com/

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
